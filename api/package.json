{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "api"
  ],
  "scripts": {
    "format": "api/node_modules/.bin/prettier . --write",
    "format:check": "api/node_modules/.bin/prettier . --check",
    "openapi:lint": "npx redocly lint ./docs/openapi.yml",
    "workspaces:lint": "npm run lint --workspaces",
    "workspaces:build": "npm run build --workspaces",
    "lint": "npm run openapi:lint && npm run workspaces:lint",
    "build": "npm run workspaces:build"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^9.39.4",
    "@redocly/cli": "^2.25.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-sql": "^0.20.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "yaml": "^2.8.3"
  }
}
