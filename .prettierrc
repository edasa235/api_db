{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "arrowParens": "always",
  "endOfLine": "lf",
  "plugins": ["prettier-plugin-sql"],
  "overrides": [
    {
      "files": "*.sql",
      "options": {
        "formatter": "sql-formatter",
        "language": "postgresql",
        "keywordCase": "upper",
        "dataTypeCase": "upper",
        "functionCase": "lower",
        "identifierCase": "preserve",
        "indentStyle": "standard",
        "logicalOperatorNewline": "after",
        "expressionWidth": 100,
        "linesBetweenQueries": 1,
        "denseOperators": false,
        "newlineBeforeSemicolon": false
      }
    }
  ]
}
